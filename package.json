  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "lite-server": "^2.3.0",
    "onchange": "^3.3.0",
    "parallelshell": "^3.0.1",
    "sass": "^1.80.6"
  },
  "dependencies": {
    "bootstrap": "^4.4.1",
    "jquery": "^3.4.1",
    "popper.js": "^1.12.9"
  }
}
