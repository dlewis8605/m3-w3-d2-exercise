{
  "name": "scss-demo",
  "version": "1.0.0",
  "description": "This is a scss demo",
  "main": "sass-demo1.html",
  "scripts": {
    "lite": "lite-server",
    "scss": "sass css:css --no-source-map",
    "start": "npm run watch:all",
    "test": "echo \"Error: no test specified\" && exit 1",
    "watch:scss": "sass --watch css:css --no-source-map",
    "watch:all": "concurrently \"npm run watch:scss\" \"npm run lite\""
  },
